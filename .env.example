# =============================================================
# CodePulse — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# =============================================================

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://codepulse:codepulse_dev_password@localhost:5432/codepulse_db"

# ── Redis ─────────────────────────────────────────────────────
# Redis connection URL (BullMQ + cache)
REDIS_URL="redis://:codepulse_redis_password@localhost:6379"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_openssl_rand_base64_32"

# Google OAuth (university Google Workspace)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# GitHub OAuth (for platform connection, NOT site login)
AUTH_GITHUB_ID="your-github-oauth-app-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-client-secret"

# ── GitHub Adapter ────────────────────────────────────────────
# Comma-separated PAT pool (min 1, up to 5 for MVP)
GITHUB_PAT_POOL="ghp_token1,ghp_token2"

# ── Encryption ────────────────────────────────────────────────
# 32-byte hex key for encrypting OAuth tokens at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="CHANGE_ME_64_hex_chars_here_000000000000000000000000000000000000"

# ── Application ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Institution slug for single-tenant MVP
DEFAULT_INSTITUTION_SLUG="lpu"

# ── Logging ───────────────────────────────────────────────────
# "debug" | "info" | "warn" | "error"
LOG_LEVEL="info"

# ── Snapshot Store ────────────────────────────────────────────
# For MVP: local filesystem path relative to project root
# For production: swap to S3-compatible (see SnapshotStore interface)
SNAPSHOT_STORE_TYPE="local"
SNAPSHOT_STORE_PATH="./snapshots"

# S3 (future — leave blank for local dev)
# SNAPSHOT_S3_BUCKET=""
# SNAPSHOT_S3_REGION=""
# SNAPSHOT_S3_ACCESS_KEY=""
# SNAPSHOT_S3_SECRET_KEY=""
# SNAPSHOT_S3_ENDPOINT=""

# ── Worker ────────────────────────────────────────────────────
# Number of concurrent workers per queue
WORKER_CONCURRENCY_GITHUB="3"
WORKER_CONCURRENCY_CODEFORCES="1"
WORKER_CONCURRENCY_LEETCODE="1"

# ── Feature Flags ─────────────────────────────────────────────
FEATURE_DARK_MODE="true"
FEATURE_PUBLIC_PROFILES="true"
